{
  "name": "@6xargs/cli",
  "version": "0.1.2",
  "description": "Operational memory CLI for offensive security firms",
  "bin": {
    "6xargs": "./dist/index.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "build:binary": "tsup --format cjs --outDir dist-cjs --no-splitting && pkg dist-cjs/index.js --targets node20-linux-x64,node20-macos-x64,node20-win-x64 --out-path bin/",
    "publish:dry-run": "pnpm publish --dry-run --no-git-checks",
    "test": "vitest run",
    "test:unit": "vitest run tests/lib",
    "test:integration": "vitest run tests/commands",
    "test:e2e": "vitest run tests/e2e",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "pkg": {
    "scripts": "dist-cjs/**/*.js",
    "assets": [],
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-win-x64"
    ],
    "outputPath": "bin/"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "ink": "^5.0.1",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "undici": "^7.2.3",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msw"]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "msw": "^2.4.9",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
